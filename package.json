{
    "name": "lindeneg.org",
    "private": true,
    "version": "1.0.0",
    "workspaces": [
        "packages/shared",
        "packages/server",
        "packages/client"
    ],
    "scripts": {
        "start": "npm run start -w packages/server",
        "bootstrap": "bash ./scripts/bootstrap",
        "dev": "node scripts/dev.mjs",
        "fix-timestamps": "npm run fix-timestamps -w packages/server",
        "dev:server": "npm run dev -w packages/server",
        "dev:client": "npm run dev -w packages/client",
        "build:shared": "npm run build -w packages/shared",
        "build:server": "npm run build -w packages/server",
        "build:client": "npm run build -w packages/client",
        "build": "npm run build:shared && npm run build:server && npm run build:client",
        "db:migrate": "npm run db:migrate -w packages/server",
        "db:generate": "npm run db:generate -w packages/server",
        "db:studio": "npm run db:studio -w packages/server",
        "clean:server": "rm -rf packages/server/node_modules packages/server/src/generated packages/server/dist",
        "clean:server:hard": "npm run clean:server && rm -rf packages/server/data",
        "clean:client": "rm -rf packages/client/node_modules packages/client/dist",
        "clean:shared": "rm -rf packages/shared/node_modules packages/shared/dist",
        "clean": "npm run clean:shared && npm run clean:client && npm run clean:server",
        "clean:hard": "npm run clean:shared && npm run clean:client && npm run clean:server:hard"
    },
    "devDependencies": {
        "@types/node": "25.3.0",
        "typescript": "5.9.3"
    },
    "dependencies": {
        "@lindeneg/cl-env": "0.1.3"
    }
}
